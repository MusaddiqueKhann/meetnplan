rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles — keyed by Firebase Auth UID
    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Rooms — anyone authenticated can read, only admins can write
    match /rooms/{roomId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // Bookings — anyone authenticated can read and create.
    // Delete: owner (by email) or admin.
    // Update: owner (by email), admin, or restoring a waiting_for_action
    //   booking to approved (needed when a client meeting is withdrawn by its owner).
    match /bookings/{bookingId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.ownerEmail == request.auth.token.email || isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.ownerEmail == request.auth.token.email ||
        isAdmin() ||
        // Any authenticated user can progress a priority approval (approve/reject/partial-approve)
        resource.data.status == 'pending_priority_approval' ||
        // Any authenticated user can cancel an approved meeting when a fully-approved priority
        // request is doing the final atomic cancellation of conflicting meetings
        (resource.data.status == 'approved' &&
         request.resource.data.status == 'cancelled' &&
         request.resource.data.cancelledByPriorityId != null) ||
        // Legacy: restoring a waiting_for_action booking to approved
        (resource.data.status == 'waiting_for_action' &&
         request.resource.data.status == 'approved' &&
         request.resource.data.priorityRequestId == null) ||
        // Legacy: approving a priority_pending booking when its last conflict is resolved
        (resource.data.status == 'priority_pending' &&
         request.resource.data.status == 'approved')
      );
    }

    // Settings — publicly readable (needed before auth for companies list), admin-only write
    match /settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Notifications — users can read/update their own, any authenticated user can create
    match /notifications/{notifId} {
      allow read:   if isAuthenticated() && (
        resource.data.toEmail == request.auth.token.email || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.toEmail == request.auth.token.email || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.toEmail == request.auth.token.email || isAdmin()
      );
    }

    // Meeting History — all authenticated users can read and create.
    // Delete: owner of the entry (by email) or admin.
    match /meetingHistory/{historyId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (
        resource.data.performedByEmail == request.auth.token.email || isAdmin()
      );
    }
  }
}
